---
import "~/styles/globals.css";

import AppLayout from "~/components/app/AppLayout";
import PortfolioEntry from "~/components/portfolio/PortfolioEntry";
import Head from "~/layouts/components/Head.astro";
import { type PortfolioFrontmatter } from "~/types/frontmatter";

const { title, description, content } = Astro.props;

export type Props = {
  title?: string;
  description?: string;
  content?: PortfolioFrontmatter;
};
---

<!DOCTYPE html>
<html lang={Astro.currentLocale ?? "en"}>
  <Head title={title} description={description} />
  <AppLayout currentPathName={Astro.url.pathname} locale={Astro.currentLocale ?? "en"} client:visible>
    <PortfolioEntry {...content} client:visible>
      <slot />
    </PortfolioEntry>
  </AppLayout>
</html>
