---
import { getCollection } from "astro:content";
import DefaultPageLayout from "~/layouts/default.astro";
import { type PortfolioFrontmatter } from "~/types/frontmatter";
import { HomeSections } from "~/components/app/home/HomeSections";

const description = `Hi! I'm Harman. I am a developer who loves to make cool and awesome web applications that rock the world.`;

const portfolioItems = await getCollection("portfolio");
---

<DefaultPageLayout description={description}>
  <HomeSections
    locale={Astro.currentLocale ?? "en"}
    containerClassName="container mx-auto"
    items={portfolioItems.map(
      (item) => ({ ...item.data, slug: item.id } as PortfolioFrontmatter)
    )}
    client:visible
  />
</DefaultPageLayout>
